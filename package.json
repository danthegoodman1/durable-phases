{
  "name": "nodetsesmtemplate",
  "version": "0.0.1",
  "type": "module",
  "description": "Node TS ESM Template",
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "pg": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "tsx": "^4.19.0",
    "typescript": "~5.8.0",
    "vitest": "^4.1.5"
  },
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "demo": "tsx src/demos/index.ts",
    "test": "vitest run",
    "test:soak": "DURABLE_SOAK=1 vitest run",
    "benchmark": "tsx src/benchmarks/sqlite.ts",
    "benchmark:null": "tsx src/benchmarks/null.ts",
    "benchmark:null:processes": "tsx src/benchmarks/null-processes.ts",
    "benchmark:sqlite": "tsx src/benchmarks/sqlite.ts",
    "benchmark:sqlite:processes": "tsx src/benchmarks/sqlite-processes.ts",
    "benchmark:postgres": "tsx src/benchmarks/postgres.ts",
    "benchmark:postgres:diagnose": "tsx src/benchmarks/postgres.ts --diagnose",
    "benchmark:postgres:processes": "tsx src/benchmarks/postgres-processes.ts",
    "benchmark:rust-parity": "node scripts/rust-parity-bench.mjs",
    "postgres:up": "docker compose -f docker-compose.postgres.yml up -d --wait",
    "postgres:down": "docker compose -f docker-compose.postgres.yml down -v",
    "test:postgres": "DURABLE_POSTGRES_URL=${DURABLE_POSTGRES_URL:-postgresql://durable:durable@127.0.0.1:55432/durable} vitest run test/postgres-conformance.test.ts test/postgres.test.ts test/postgres-benchmark.test.ts",
    "watch": "tsx watch src/index.ts",
    "build": "tsc"
  },
  "author": "danthegoodman1",
  "license": "ISC"
}
