{
  "name": "nodetsesmtemplate",
  "version": "0.0.1",
  "type": "module",
  "description": "Node TS ESM Template",
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "~5.8.0",
